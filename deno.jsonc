{
  "name": "@md/localman",
  "version": "0.1.1",
  "license": "ISC",
  "exports": "./src/mod.ts",
  "tasks": {
    "serve": "deno run -A ./src/mod.ts --keep-hostname work deno run -A fixtures/echo-server.ts",
    "test": "deno test -A"
  },
  "publish": {
    "exclude": [
      ".github/",
      ".gitignore",
      "fixtures/",
      "./**/*.test.ts"
    ]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.6",
    "@std/net": "jsr:@std/net@^1.0.6"
  }
}
